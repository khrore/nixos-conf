{
  "$schema": "https://opencode.ai/config.json",
  "theme": "gruvbox",
  "formatter": {
    "rustfmt": {
      "command": [
        "rustfmt",
        "--edition",
        "2024",
        "$FILE"
      ],
      "extensions": [
        ".rs"
      ]
    }
  },
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "ruff": {
      "command": [
        "ruff",
        "server"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    }
  },
  "permission": {
    "webfetch": "allow"
  },
  "agent": {
    "workflow-orchestrator": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "analyzer": "allow",
          "researcher": "allow",
          "planner": "allow",
          "python-coder": "allow",
          "rust-coder": "allow",
          "vue-coder": "allow",
          "typescript-coder": "allow",
          "general-coder": "allow",
          "python-reviewer": "allow",
          "rust-reviewer": "allow",
          "vue-reviewer": "allow",
          "typescript-reviewer": "allow",
          "general-reviewer": "allow",
          "tester": "allow",
          "technical-writer": "allow",
          "summarizer": "allow"
        }
      }
    },
    "analyzer": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "researcher": "allow"
        }
      }
    },
    "researcher": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "planner": "allow"
        }
      }
    },
    "planner": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "python-coder": "allow",
          "rust-coder": "allow",
          "vue-coder": "allow",
          "typescript-coder": "allow",
          "general-coder": "allow"
        }
      }
    },
    "python-coder": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "python-reviewer": "allow"
        }
      }
    },
    "rust-coder": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "rust-reviewer": "allow"
        }
      }
    },
    "vue-coder": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "vue-reviewer": "allow"
        }
      }
    },
    "typescript-coder": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "typescript-reviewer": "allow"
        }
      }
    },
    "general-coder": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "general-reviewer": "allow"
        }
      }
    },
    "python-reviewer": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "python-coder": "allow",
          "tester": "allow"
        }
      }
    },
    "rust-reviewer": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "rust-coder": "allow",
          "tester": "allow"
        }
      }
    },
    "vue-reviewer": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "vue-coder": "allow",
          "tester": "allow"
        }
      }
    },
    "typescript-reviewer": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "typescript-coder": "allow",
          "tester": "allow"
        }
      }
    },
    "general-reviewer": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "general-coder": "allow",
          "tester": "allow"
        }
      }
    },
    "tester": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "technical-writer": "allow"
        }
      }
    },
    "technical-writer": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny",
          "summarizer": "allow"
        }
      }
    },
    "summarizer": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny"
        }
      }
    }
  }
}
